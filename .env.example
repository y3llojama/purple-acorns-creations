# App URL — used for CORS (set to your Vercel domain in production, e.g. https://purple-acorns.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — public (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# PostgreSQL connection string — get from: cd infra && terraform output -raw database_url
DATABASE_URL=

# Admin auth allowlist (server-only)
ADMIN_EMAILS=admin@example.com,owner@example.com

# AI providers (Plan 2 — leave blank for now)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
