# App URL — used for CORS (set to your Vercel domain in production, e.g. https://purple-acorns.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — public (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# PostgreSQL connection string — get from: cd infra && terraform output -raw database_url
DATABASE_URL=

# Admin auth allowlist (server-only)
ADMIN_EMAILS=admin@example.com,owner@example.com

# Newsletter — Resend email delivery (https://resend.com)
RESEND_API_KEY=
NEWSLETTER_FROM_EMAIL=newsletter@yourdomain.com
NEWSLETTER_FROM_NAME=Purple Acorns Creations
# Comma-separated admin emails that receive a preview before each send
NEWSLETTER_ADMIN_EMAILS=admin@example.com
# Resend webhook secret — from Resend dashboard → Webhooks
RESEND_WEBHOOK_SECRET=

# Newsletter — scheduled send via Vercel Cron
CRON_SECRET=

# AI newsletter draft generation — set ai_provider in Admin → Integrations (claude | openai | groq)
AI_API_KEY=

# Site URL — used in newsletter links and UTM tracking
NEXT_PUBLIC_SITE_URL=https://purpleacornz.com
